# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartgrid
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URLs (localhost defaults, overridden in docker-compose)
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartgrid
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/smartgrid
